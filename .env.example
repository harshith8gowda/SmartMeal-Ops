# Neon Postgres (pooled connection for the app)
DATABASE_URL="postgresql://<user>:<password>@<neon-host>/<db>?sslmode=require"
# Direct connection for Prisma migrations (Neon)
DATABASE_URL_UNPOOLED="postgresql://<user>:<password>@<neon-host>/<db>?sslmode=require"

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# OpenAI structured meal planning (leave empty for mock-safe fallback)
OPENAI_API_KEY="sk-..."

# Swiggy Builders Club MCP (leave SWIGGY_MCP_ACCESS_TOKEN empty for mock-safe fallback)
SWIGGY_MCP_ACCESS_TOKEN=""
SWIGGY_FOOD_MCP_URL="https://mcp.swiggy.com/food"
SWIGGY_INSTAMART_MCP_URL="https://mcp.swiggy.com/im"
SWIGGY_DINEOUT_MCP_URL="https://mcp.swiggy.com/dineout"

# Swiggy OAuth 2.1 PKCE (set after signing the integration agreement)
SWIGGY_MCP_AUTH_BASE_URL="https://mcp.swiggy.com"
SWIGGY_MCP_CLIENT_ID=""
SWIGGY_MCP_REDIRECT_URI="https://smart-meal-ops.vercel.app/api/swiggy/callback"
SWIGGY_MCP_SCOPES="mcp:tools"

# Encryption key for per-user Swiggy tokens (32+ bytes, generate with `openssl rand -hex 32`)
TOKEN_ENCRYPTION_KEY=""

# Upstash Redis for rate limiting (optional — local in-memory fallback is used if omitted)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
